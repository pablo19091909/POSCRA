{
  "Service": {
    "Name": "POS.Api",
    "Version": "1.0.0"
  },
  "ConnectionStrings": {
    "PosDatabase": ""
  },
  "Authentication": {
    "Enabled": false,
    "EnableLegacyHashUpgrade": false,
    "BcryptWorkFactor": 12
  },
  "FeatureFlags": {
    "EnableVentasApiWrite": false
  },
  "Jwt": {
    "Issuer": "POS.Api",
    "Audience": "PulperiaPOS.WPF",
    "SigningKey": "CONFIGURAR_MEDIANTE_SECRETO_LOCAL_O_VARIABLE_ENTORNO",
    "AccessTokenMinutes": 45
  },
  "RateLimiting": {
    "Login": {
      "PermitLimit": 5,
      "WindowSeconds": 60
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
