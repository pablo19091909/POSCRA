<Window x:Class="PulperiaPOS.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PulperiaPOS"
        mc:Ignorable="d"
        Title="Inicio Sesión Punto de Venta" Height="500" Width="650"
        Background="#FF144734" Icon="{DynamicResource AppIcon}"
        ResizeMode="CanMinimize" 
        SizeToContent="Manual"
        WindowStartupLocation="CenterScreen">

    <Grid Width="610" Height="460" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Imagen -->
        <Image Source="/Imagenes/Blanco1.png"
               Grid.Row="0"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Stretch="Uniform"/>

        <!-- Formulario -->
        <Grid Grid.Row="1" Margin="60,10,60,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Usuario:" Foreground="White" Grid.Row="0"/>
            <TextBox x:Name="txtUsuario" Margin="0 5" Grid.Row="1"/>

            <TextBlock Text="Contraseña:" Foreground="White" Grid.Row="2"/>
            <PasswordBox x:Name="txtContrasena" Margin="0 5" Grid.Row="3"/>

            <Button Content="Ingresar"
        Click="BtnIngresar_Click"
        Margin="0 10"
        Grid.Row="4"
        HorizontalAlignment="Stretch"
        IsDefault="True"/>
        </Grid>
    </Grid>
</Window>
