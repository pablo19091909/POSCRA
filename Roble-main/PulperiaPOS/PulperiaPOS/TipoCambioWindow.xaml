<Window x:Class="PulperiaPOS.TipoCambioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ingresar Tipo de Cambio"
        Height="300"
        Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#FF144734"
        Icon="{DynamicResource AppIcon}"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Tipo de cambio (compra y venta en colones)"
                   FontWeight="Bold"
                   Foreground="White"
                   FontSize="16"
                   Grid.Row="0"
                   Margin="0,0,0,10"/>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,5">
            <TextBlock Text="Compra: ₡"
                       Width="100"
                       VerticalAlignment="Center"
                       Foreground="White"/>
            <TextBox x:Name="CompraTextBox"
                     Width="200"
                     Margin="0,0,0,5"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,5">
            <TextBlock Text="Venta: ₡"
                       Width="100"
                       VerticalAlignment="Center"
                       Foreground="White"/>
            <TextBox x:Name="VentaTextBox"
                     Width="200"/>
        </StackPanel>

        <Button Content="Guardar"
                Grid.Row="3"
                Click="Guardar_Click"
                Margin="0,20,0,0"
                Width="100"
                Background="#28a745"
                Foreground="White"
                HorizontalAlignment="Left"/>
    </Grid>
</Window>
