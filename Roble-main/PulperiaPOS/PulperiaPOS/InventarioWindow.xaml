<Window x:Class="PulperiaPOS.InventarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PulperiaPOS"
        mc:Ignorable="d"
        Title="Gestión de Inventario" Height="500" Width="800"
        Icon="{DynamicResource AppIcon}"
        WindowStartupLocation="CenterScreen"
        Background="#FF144734"
        WindowState="Maximized"
        Loaded="Window_Loaded">


    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barra de búsqueda -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Caja de búsqueda -->
            <TextBox x:Name="txtBuscar" Grid.Column="0" Margin="0,0,10,0"
             Text="Buscar producto por ID o Nombre" Foreground="Gray"
             GotFocus="txtBuscar_GotFocus" LostFocus="txtBuscar_LostFocus"
             TextChanged="txtBuscar_TextChanged" Height="30"/>

            <!-- Botón Buscar -->
            <Button Content="Buscar" Click="BtnBuscar_Click" Grid.Column="1"
            Margin="5,0" Width="80" Height="30" HorizontalAlignment="Left"/>

            <!-- Botón Exportar PDF -->
            <Button Content="Exportar PDF" Click="BtnExportarPDF_Click"
            Grid.Column="2" Margin="5,0" Width="110" Height="30"
            Background="#28a745" Foreground="White" HorizontalAlignment="Left"/>

            <!-- Botón Agregar -->
            <Button x:Name="BtnAgregar" Content="Agregar" Click="BtnAgregar_Click"
            Grid.Column="3" Width="90" Height="30"
            Background="#28a745" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Top"/>

            <!-- Botón Refrescar -->
            <Button Content="Refrescar" Click="BtnRefrescar_Click"
            Grid.Column="4" Margin="5,0" Width="90" Height="30"
            HorizontalAlignment="Left"/>

            <!-- Botón Volver -->
            <Button Content="Volver" Click="BtnVolver_Click"
            Grid.Column="5" Margin="5,0" Width="80" Height="30"
            Background="#fd7e14" Foreground="White" HorizontalAlignment="Left"/>
        </Grid>

        <!-- Tabla -->
        <DataGrid x:Name="dgInventario"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding idProducto}" Width="Auto"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding nombre}" Width="*"/>
                <DataGridTextColumn Header="Proveedor" Binding="{Binding proveedor}" Width="*"/>
                <DataGridTextColumn Header="Costo" Binding="{Binding costo}" Width="Auto"/>
                <DataGridTextColumn Header="Precio" Binding="{Binding precio}" Width="Auto"/>
                <DataGridTextColumn Header="Stock" Binding="{Binding stock}" Width="Auto"/>
                <DataGridTextColumn Header="Vendido" Binding="{Binding vendido}" Width="Auto"/>
                <DataGridTemplateColumn Header="Acciones">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Editar" Click="BtnEditar_Click" Margin="2"
                                        Background="#ffc107" Foreground="Black"/>
                                <!-- Amarillo -->
                                <Button Content="Eliminar" Click="BtnEliminar_Click" Margin="2"
                                        Background="#dc3545" Foreground="White"/>
                                <!-- Rojo -->
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
