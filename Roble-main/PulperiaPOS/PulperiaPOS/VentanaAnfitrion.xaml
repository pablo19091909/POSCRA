<Window x:Class="PulperiaPOS.VentanaAnfitrion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PulperiaPOS"
        mc:Ignorable="d"
                WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Icon="{DynamicResource AppIcon}"
        Background="#FF144734">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Encabezado -->
            <RowDefinition Height="*"/>
            <!-- Contenido principal -->
            <RowDefinition Height="Auto"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- TÍTULO DE BIENVENIDA -->
        <TextBlock x:Name="TextoBienvenida"
                   Text="Bienvenido Anfitrion:"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,20"/>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- BOTONES PRINCIPALES -->
            <UniformGrid Grid.Column="0" Rows="5" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="20">
                <Button Content="Inventario" Click="BtnVerInventario_Click" Margin="10" FontSize="16" Height="60"/>
                <Button Content="Clientes" Click="BtnClientes_Click" Margin="10" FontSize="16" Height="60"/>
                <Button Content="Ventas" Click="BtnVentasPage_Click" Margin="10" FontSize="16" Height="60"/>
                <Button Content="Cierre Caja" Click="BtnCierreCajaPage_Click" Margin="10" FontSize="16" Height="60"/>
                <Button Content="Tipo de Cambio" Click="BtnTipoCambio_Click" Margin="10,0,10,0" FontSize="16" Height="60"/>
            </UniformGrid>

            <!-- PANEL DERECHO -->
            <StackPanel Grid.Column="1" Margin="20" VerticalAlignment="Top" HorizontalAlignment="Center">
                <Image Source="/Imagenes/Blanco3.png"
                       Width="180"
                       Height="250"
                       Stretch="Uniform"
                       Margin="0,0,0,20"/>
            </StackPanel>
        </Grid>

        <!-- PIE DE PÁGINA -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,10,10">
            <Button Content="Cerrar Sesión" Click="BtnLogout_Click" Width="180" Height="50" Background="Crimson" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
