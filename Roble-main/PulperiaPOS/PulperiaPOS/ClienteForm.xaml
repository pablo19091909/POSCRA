<Window x:Class="PulperiaPOS.ClienteForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PulperiaPOS"
        mc:Ignorable="d"
        Title="Formulario de Cliente"
        Height="450"
        Width="800"
        Icon="{DynamicResource AppIcon}"
        Background="#FF144734"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="500" HorizontalAlignment="Center">
                <Label Content="Nombre:" Foreground="White"/>
                <TextBox x:Name="txtNombre" Margin="0,0,0,10"/>

                <Label Content="Saldo:" Foreground="White"/>
                <TextBox x:Name="txtSaldo" Margin="0,0,0,10"/>

                <Label Content="Comprobante (texto):" Foreground="White"/>
                <TextBox x:Name="txtComprobante" Margin="0,0,0,10"/>

                <!-- Aquí más adelante se puede poner un botón de subir imagen -->

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Guardar" Width="80" Click="BtnGuardar_Click" Margin="5"/>
                    <Button Content="Cancelar" Width="80" Click="BtnCancelar_Click" Margin="5"/>
                </StackPanel>
                <Button Grid.Column="4" Content="Volver" Click="BtnVolver_Click" Width="80" Margin="5,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
