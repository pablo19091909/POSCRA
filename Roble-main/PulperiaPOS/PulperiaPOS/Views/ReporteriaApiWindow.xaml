<Window x:Class="PulperiaPOS.Views.ReporteriaApiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reporteria API"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#FF144734"
        Icon="{DynamicResource AppIcon}">
    <Window.Resources>
        <Style x:Key="SummaryTileStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D7DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,12">
            <Button Content="Volver" Width="110" Height="36" Background="#fd7e14" Foreground="White" Click="BtnVolver_Click" DockPanel.Dock="Left"/>
            <TextBlock Text="Reporteria API" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </DockPanel>

        <Border Grid.Row="1" Background="#0F3A2B" BorderBrush="#2aa865" BorderThickness="1" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="txtModo" Text="Modo Reporteria API" Foreground="#FFD84D" FontWeight="Bold" Margin="0,0,18,0"/>
                <TextBlock Text="Origen: Reporte API / Historico SQL / Comparativo" Foreground="White" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Desde:" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <DatePicker x:Name="dpDesde" Width="130" Margin="0,0,12,0"/>
            <TextBlock Text="Hasta:" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <DatePicker x:Name="dpHasta" Width="130" Margin="0,0,12,0"/>
            <TextBlock Text="Estado:" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="cmbEstado" Width="120" Margin="0,0,12,0" SelectionChanged="Filtros_Changed">
                <ComboBoxItem Content="Todas" IsSelected="True"/>
                <ComboBoxItem Content="Activas"/>
                <ComboBoxItem Content="Reversadas"/>
            </ComboBox>
            <TextBlock Text="Origen:" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="cmbOrigen" Width="150" Margin="0,0,12,0" SelectionChanged="Filtros_Changed">
                <ComboBoxItem Content="Todos" IsSelected="True"/>
                <ComboBoxItem Content="Venta API"/>
                <ComboBoxItem Content="Caja API"/>
                <ComboBoxItem Content="Historico SQL"/>
            </ComboBox>
            <TextBlock Text="Turno/Caja:" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="txtTurnoFiltro" Width="150" Margin="0,0,12,0" TextChanged="Filtros_Changed"/>
            <CheckBox x:Name="chkSoloEfectivo" Content="Efectivo" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0" Checked="Filtros_Changed" Unchecked="Filtros_Changed"/>
            <Button Content="Refrescar API" Width="130" Height="32" Background="#28a745" Foreground="White" Click="BtnRefrescar_Click"/>
        </StackPanel>

        <TabControl Grid.Row="3">
            <TabItem Header="Resumen">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <UniformGrid Columns="4" Margin="0,0,0,12">
                            <Border Style="{StaticResource SummaryTileStyle}">
                                <StackPanel><TextBlock Text="Ventas brutas"/><TextBlock x:Name="txtVentasBrutas" FontSize="22" FontWeight="Bold"/></StackPanel>
                            </Border>
                            <Border Style="{StaticResource SummaryTileStyle}">
                                <StackPanel><TextBlock Text="Monto reversado"/><TextBlock x:Name="txtMontoReversado" FontSize="22" FontWeight="Bold"/></StackPanel>
                            </Border>
                            <Border Style="{StaticResource SummaryTileStyle}">
                                <StackPanel><TextBlock Text="Ventas netas"/><TextBlock x:Name="txtVentasNetas" FontSize="22" FontWeight="Bold"/></StackPanel>
                            </Border>
                            <Border Style="{StaticResource SummaryTileStyle}">
                                <StackPanel><TextBlock Text="Cantidad reversas"/><TextBlock x:Name="txtCantidadReversas" FontSize="22" FontWeight="Bold"/></StackPanel>
                            </Border>
                            <Border Style="{StaticResource SummaryTileStyle}">
                                <StackPanel><TextBlock Text="Efectivo bruto"/><TextBlock x:Name="txtEfectivoBruto" FontSize="22" FontWeight="Bold"/></StackPanel>
                            </Border>
                            <Border Style="{StaticResource SummaryTileStyle}">
                                <StackPanel><TextBlock Text="Reversas efectivo"/><TextBlock x:Name="txtReversasEfectivo" FontSize="22" FontWeight="Bold"/></StackPanel>
                            </Border>
                            <Border Style="{StaticResource SummaryTileStyle}">
                                <StackPanel><TextBlock Text="Efectivo neto"/><TextBlock x:Name="txtEfectivoNeto" FontSize="22" FontWeight="Bold"/></StackPanel>
                            </Border>
                            <Border Style="{StaticResource SummaryTileStyle}">
                                <StackPanel><TextBlock Text="CierreDiferencia"/><TextBlock x:Name="txtCierreDiferencia" FontSize="22" FontWeight="Bold"/></StackPanel>
                            </Border>
                        </UniformGrid>
                        <UniformGrid Columns="4">
                            <Border Style="{StaticResource SummaryTileStyle}">
                                <StackPanel><TextBlock Text="Turnos abiertos"/><TextBlock x:Name="txtTurnosAbiertos" FontSize="22" FontWeight="Bold"/></StackPanel>
                            </Border>
                            <Border Style="{StaticResource SummaryTileStyle}">
                                <StackPanel><TextBlock Text="Turnos cerrados"/><TextBlock x:Name="txtTurnosCerrados" FontSize="22" FontWeight="Bold"/></StackPanel>
                            </Border>
                            <Border Style="{StaticResource SummaryTileStyle}">
                                <StackPanel><TextBlock Text="Efectivo esperado"/><TextBlock x:Name="txtEfectivoEsperado" FontSize="22" FontWeight="Bold"/></StackPanel>
                            </Border>
                            <Border Style="{StaticResource SummaryTileStyle}">
                                <StackPanel><TextBlock Text="Diferencia cerrada"/><TextBlock x:Name="txtDiferencia" FontSize="22" FontWeight="Bold"/></StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Ventas">
                <DataGrid x:Name="dgVentas" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Factura" Binding="{Binding Factura}"/>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha}"/>
                        <DataGridTextColumn Header="Estado" Binding="{Binding Estado}"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding Total}"/>
                        <DataGridTextColumn Header="Metodo" Binding="{Binding MetodoPago}"/>
                        <DataGridTextColumn Header="Origen" Binding="{Binding Origen}"/>
                        <DataGridTextColumn Header="Impacto neto" Binding="{Binding ImpactoNeto}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Reversas">
                <DataGrid x:Name="dgReversas" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Factura" Binding="{Binding Factura}"/>
                        <DataGridTextColumn Header="Monto" Binding="{Binding Monto}"/>
                        <DataGridTextColumn Header="Moneda" Binding="{Binding Moneda}"/>
                        <DataGridTextColumn Header="Fecha UTC" Binding="{Binding FechaUtc}"/>
                        <DataGridTextColumn Header="Estado" Binding="{Binding Estado}"/>
                        <DataGridTextColumn Header="Consistente" Binding="{Binding Consistente}"/>
                        <DataGridTextColumn Header="Motivo" Binding="{Binding Motivo}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Caja">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dgTurnos" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,6">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Caja" Binding="{Binding CajaCodigo}"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}"/>
                            <DataGridTextColumn Header="Fondo" Binding="{Binding FondoInicial}"/>
                            <DataGridTextColumn Header="Esperado" Binding="{Binding EfectivoEsperado}"/>
                            <DataGridTextColumn Header="Contado" Binding="{Binding EfectivoContado}"/>
                            <DataGridTextColumn Header="Diferencia" Binding="{Binding Diferencia}"/>
                            <DataGridTextColumn Header="Fuente" Binding="{Binding Fuente}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <DataGrid x:Name="dgMovimientos" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding TipoMovimiento}"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}"/>
                            <DataGridTextColumn Header="Monto" Binding="{Binding Monto}"/>
                            <DataGridTextColumn Header="Moneda" Binding="{Binding Moneda}"/>
                            <DataGridTextColumn Header="Origen" Binding="{Binding Origen}"/>
                            <DataGridTextColumn Header="Factura" Binding="{Binding Factura}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Auditoria">
                <DataGrid x:Name="dgAlertas" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Codigo" Binding="{Binding Codigo}" Width="180"/>
                        <DataGridTextColumn Header="Severidad" Binding="{Binding Severidad}" Width="90"/>
                        <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="80"/>
                        <DataGridTextColumn Header="Descripcion" Binding="{Binding Descripcion}" Width="*"/>
                        <DataGridTextColumn Header="Accion" Binding="{Binding AccionRecomendada}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <TextBlock x:Name="txtEstado" Grid.Row="4" Foreground="#FFD84D" FontWeight="Bold" Margin="0,10,0,0"/>
    </Grid>
</Window>
