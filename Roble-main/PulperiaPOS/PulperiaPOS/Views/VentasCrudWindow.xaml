<Window x:Class="PulperiaPOS.Views.VentasCrudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PulperiaPOS.Views"
        mc:Ignorable="d"
        Title="Gestión de Ventas"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#FF144734"
        Icon="{DynamicResource AppIcon}">

    <Grid Margin="20" Background="#FF144734">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Encabezado -->
            <RowDefinition Height="*"/>
            <!-- Tabla -->
            <RowDefinition Height="Auto"/>
            <!-- Pie -->
        </Grid.RowDefinitions>

        <!-- Encabezado: Botones de acción -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10" Grid.Row="0">
            <Button Content="Refrescar" Click="RefrescarVentas_Click"
                    Width="100" Height="35" Margin="5,0"
                    Background="#3498db" Foreground="White"/>
            <Button Content="Eliminar Venta" Click="EliminarVenta_Click"
                    Width="130" Height="35"
                    Margin="20,0,0,0"
                    Background="#dc3545" Foreground="White"/>
            <Button Content="Volver" Click="BtnVolver_Click"
        Width="117" Height="35"
        Margin="20,0,0,0"
        Background="#fd7e14" Foreground="White"/>

        </StackPanel>

        <!-- Tabla de ventas -->
        <DataGrid x:Name="VentasDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  SelectionMode="Single"
                  Margin="0,10,0,10"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#FFF0F0F0"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Factura" Binding="{Binding factura}" Width="70"/>
                <DataGridTextColumn Header="Cliente" Binding="{Binding nombre_cliente}" Width="120"/>
                <DataGridTextColumn Header="ID Cliente" Binding="{Binding cliente_id}" Width="100"/>
                <DataGridTextColumn Header="Total" Binding="{Binding total}" Width="100"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding fecha}" Width="100"/>
                <DataGridTextColumn Header="Hora" Binding="{Binding hora}" Width="100"/>
                <DataGridTextColumn Header="ID Usuario" Binding="{Binding usuario_id}" Width="100"/>
                <DataGridTextColumn Header="Método Pago" Binding="{Binding metodo_pago}" Width="120"/>
                <DataGridTextColumn Header="Voucher" Binding="{Binding numero_voucher}" Width="120"/>
                <DataGridTextColumn Header="Comprobante" Binding="{Binding numero_comprobante}" Width="120"/>
                <DataGridTextColumn Header="Monto Pagado" Binding="{Binding monto_pagado}" Width="100"/>
                <DataGridTextColumn Header="Vuelto" Binding="{Binding vuelto}" Width="100"/>
                <DataGridTemplateColumn Header="Detalle">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Ver Detalle" Click="VerDetalleVenta_Click"
                                    Tag="{Binding factura}" Background="#FF3498DB" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Acciones">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Reimprimir" Click="BtnReimprimir_Click" Tag="{Binding}" Background="#007bff" Foreground="White" Margin="4,0" Padding="4,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Pie de página -->
        <TextBlock Text="* Seleccione una fila para eliminar o ver su detalle."
                   Grid.Row="2"
                   Foreground="LightGray"
                   Margin="0,5,0,0"
                   FontStyle="Italic"/>
    </Grid>
</Window>
