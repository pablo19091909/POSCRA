<Window x:Class="PulperiaPOS.Views.ReversaVentaApiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modo Reversa API"
        Width="520"
        Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF144734"
        Icon="{DynamicResource AppIcon}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Modo Reversa API"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"/>
            <TextBlock x:Name="ResumenTextBlock"
                       Margin="0,10,0,0"
                       Foreground="#FFFFD54F"
                       TextWrapping="Wrap"/>
            <TextBlock Text="La reversa es total e irreversible. Inventario y caja serán compensados por POS.Api."
                       Margin="0,8,0,0"
                       Foreground="White"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="Razón obligatoria:"
                   Margin="0,20,0,6"
                   Foreground="White"
                   FontWeight="Bold"/>

        <TextBox x:Name="MotivoTextBox"
                 Grid.Row="2"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MaxLength="250"
                 VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Cancelar"
                    Width="110"
                    Height="34"
                    Margin="0,0,10,0"
                    Click="Cancelar_Click"/>
            <Button Content="Confirmar Reversa"
                    Width="160"
                    Height="34"
                    Background="#dc3545"
                    Foreground="White"
                    Click="Confirmar_Click"/>
        </StackPanel>
    </Grid>
</Window>
