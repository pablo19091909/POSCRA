<Window x:Class="PulperiaPOS.Views.RetirosCajaPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PulperiaPOS.Views"
        mc:Ignorable="d"
        Title="Retiros de Caja"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#FF144734"
        Icon="{DynamicResource AppIcon}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Encabezado -->
            <RowDefinition Height="*"/>
            <!-- Contenido -->
        </Grid.RowDefinitions>

        <!-- Encabezado con botón Volver -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Grid.Row="0" Margin="0,0,0,10">
            <Button Content="Volver"
                    Width="90"
                    Height="35"
                    Background="#fd7e14"
                    Foreground="White"
                    Click="BtnVolver_Click"/>
        </StackPanel>

        <!-- Contenido principal -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <!-- Formulario -->
                <ColumnDefinition Width="3*"/>
                <!-- Historial -->
            </Grid.ColumnDefinitions>

            <!-- Formulario para registrar retiro -->
            <StackPanel Grid.Column="0" Margin="10" VerticalAlignment="Top">
                <TextBlock Text="Registrar Retiro de Caja"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,20"/>
                <TextBlock Name="txtCajaApiStatus"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"
                           Foreground="#FFFFD966"
                           FontWeight="SemiBold"
                           Margin="0,0,0,14"/>
                <TextBlock Text="Dinero en Caja (Calculado):" Foreground="White"/>
                <TextBox Name="txtDineroCaja" IsReadOnly="True" Margin="0,0,0,20" TextChanged="txtDineroCaja_TextChanged"/>

                <TextBlock Text="Monto a Retirar:" Foreground="White"/>
                <TextBox Name="txtMontoRetiro" Margin="0,0,0,10"/>

                <TextBlock Text="Motivo del Retiro:" Foreground="White"/>
                <TextBox Name="txtMotivoRetiro" Height="60" TextWrapping="Wrap" Margin="0,0,0,20"/>

               


                <Button Content="Registrar Retiro"
                        Click="RegistrarRetiro_Click"
                        Width="160"
                        Height="40"
                        Background="#28a745"
                        Foreground="White"/>
            </StackPanel>
            

            <!-- Tabla de retiros -->
            <StackPanel Grid.Column="1" Margin="10">
                <TextBlock Text="Historial de Retiros"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="White"
                           Margin="0,0,0,10"/>
                <DataGrid Name="dgRetiros"
                          AutoGenerateColumns="True"
                          Height="400"
                          Background="White"
                          AlternatingRowBackground="#FFEFEFEF"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
