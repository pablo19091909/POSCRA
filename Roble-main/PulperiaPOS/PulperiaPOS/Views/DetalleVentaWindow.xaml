<Window x:Class="PulperiaPOS.Views.DetalleVentaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PulperiaPOS.Views"
        mc:Ignorable="d"
        Title="Detalle de Venta"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#FF144734"
        Icon="{DynamicResource AppIcon}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Barra superior -->
            <RowDefinition Height="*"/>
            <!-- Tabla -->
        </Grid.RowDefinitions>

        <!-- Botón Volver -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Grid.Row="0" Margin="0,0,0,10">
            <Button Content="Volver"
                    Width="90"
                    Height="35"
                    Background="#fd7e14"
                    Foreground="White"
                    Click="BtnVolver_Click"/>
        </StackPanel>

        <!-- Tabla de detalle de productos -->
        <DataGrid x:Name="DetalleDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="0"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#FFF0F0F0"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID Detalle" Binding="{Binding idDetalle}" Width="80"/>
                <DataGridTextColumn Header="Producto ID" Binding="{Binding producto_id}" Width="100"/>
                <DataGridTextColumn Header="Nombre Producto" Binding="{Binding nombre_producto}" Width="200"/>
                <DataGridTextColumn Header="Cantidad" Binding="{Binding cantidad}" Width="80"/>
                <DataGridTextColumn Header="Precio Unitario" Binding="{Binding precio_unitario}" Width="120"/>
                <DataGridTextColumn Header="Subtotal" Binding="{Binding subtotal}" Width="100"/>
            </DataGrid.Columns>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding nombre_producto}" Value="TOTAL">
                            <Setter Property="Background" Value="LightGoldenrodYellow"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="Black"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>
    </Grid>
</Window>
