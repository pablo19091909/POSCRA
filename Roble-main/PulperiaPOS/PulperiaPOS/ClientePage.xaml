<Window x:Class="PulperiaPOS.ClientePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Clientes"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowState="Maximized"
        Background="#FF144734"
        Icon="{DynamicResource AppIcon}">


    <Window.Resources>
        <Style x:Key="PlaceholderTextBox" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid Background="White">
                            <!-- Aquí forzamos el fondo blanco -->
                            <ScrollViewer x:Name="PART_ContentHost"
                                  Background="Transparent"
                                  Foreground="Black"/>
                            <TextBlock x:Name="Placeholder"
                               Text="{Binding Tag, RelativeSource={RelativeSource AncestorType=TextBox}}"
                               Foreground="Gray"
                               Padding="5"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Visibility="Visible"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#ccc"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Barra de búsqueda -->
            <RowDefinition Height="*"/>
            <!-- Tabla -->
            <RowDefinition Height="Auto"/>
            <!-- Botones -->
        </Grid.RowDefinitions>

        <!-- Encabezado de búsqueda -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
            <TextBox x:Name="txtBuscar"
                     Width="250"
                     Height="30"
                     Style="{StaticResource PlaceholderTextBox}"
                     Tag="Buscar cliente por nombre o ID"
                     TextChanged="BtnBuscar_Click"/>
            <Button Content="Buscar" Width="70" Margin="5,0" Click="BtnBuscar_Click"/>
            <Button Content="Volver" Width="80" Margin="5,0"
                    Background="#fd7e14" Foreground="White"
                    Click="BtnVolver_Click"/>
        </StackPanel>

        <!-- Tabla de clientes -->
        <DataGrid x:Name="dataGridClientes"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="0"
                  SelectionMode="Single"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding idCliente}" Width="Auto"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding nombre}" Width="*"/>
                <DataGridTextColumn Header="Saldo" Binding="{Binding saldo}" Width="Auto"/>
                <DataGridTextColumn Header="Comprobante" Binding="{Binding comprobante}" Width="*"/>
                <DataGridTemplateColumn Header="Acción" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Liberar Saldo"
                        Background="#ffc107"
                        Foreground="Black"
                        Padding="5,2"
                        Click="BtnLiberarSaldo_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Botones de acción -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnAgregar" Content="Agregar" Click="BtnAgregar_Click"
                    Width="90" Height="35" Margin="5,0"
                    Background="#28a745" Foreground="White"/>
            <Button x:Name="BtnEditar" Content="Editar" Click="BtnEditar_Click"
                    Width="90" Height="35" Margin="5,0"
                    Background="#3498DB" Foreground="White"/>
            <Button x:Name="BtnEliminar" Content="Eliminar" Click="BtnEliminar_Click"
                    Width="90" Height="35" Margin="5,0"
                    Background="#dc3545" Foreground="White"/>
            <Button Content="Historial Liberaciones"
        Width="160"
        Margin="5,0"
        Click="BtnHistorialLiberaciones_Click"
        Background="#ffc107"
        Foreground="Black"/>

            <Button x:Name="BtnReporteClientesSaldo" Content="Reporte Saldos"
        Click="BtnReporteClientesSaldo_Click"
        Background="#FF3498DB" Foreground="White"
        Margin="5" Padding="8,4"/>



        </StackPanel>
    </Grid>
</Window>
