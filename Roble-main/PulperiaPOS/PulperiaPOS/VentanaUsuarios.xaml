<Window x:Class="PulperiaPOS.VentanaUsuarios"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PulperiaPOS"
        mc:Ignorable="d"
        Title="Gestión de Usuarios"
        Icon="{DynamicResource AppIcon}"
        Background="#FF144734"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
       >

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Título -->
            <RowDefinition Height="Auto"/>
            <!-- Búsqueda -->
            <RowDefinition Height="*"/>
            <!-- Tabla -->
            <RowDefinition Height="Auto"/>
            <!-- Botones -->
        </Grid.RowDefinitions>

        <!-- TÍTULO -->
        <TextBlock Text="Gestión de Usuarios"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- BARRA DE BÚSQUEDA -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtBuscar"
                     Grid.Column="0"
                     Margin="0,0,5,0"
                     Foreground="Gray"
                     Text="Buscar por nombre o rol"
                     GotFocus="txtBuscar_GotFocus"
                     LostFocus="txtBuscar_LostFocus"
                     TextChanged="txtBuscar_TextChanged"/>

            <Button Grid.Column="1"
                    Content="Buscar"
                    Click="BtnBuscar_Click"
                    Width="80"
                    Margin="5,0"/>

            <Button Grid.Column="2"
                    Content="Refrescar"
                    Click="BtnRefrescar_Click"
                    Width="90"
                    Margin="5,0"/>
        </Grid>

        <!-- TABLA DE USUARIOS -->
        <DataGrid x:Name="dgUsuarios"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  Margin="0,10"
                  RowBackground="White"
                  AlternatingRowBackground="#f0f0f0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding idUsuario}" Width="Auto" IsReadOnly="True"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding nombre}" Width="*"/>
                <DataGridTemplateColumn Header="Contraseña" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="******"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Rol" Binding="{Binding rol}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- BOTONES -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Agregar" Click="BtnAgregar_Click"
                    Width="100" Height="40"
                    Background="#28a745" Foreground="White" Margin="5"/>
            <Button Content="Actualizar" Click="BtnActualizar_Click"
                    Width="100" Height="40"
                    Background="#ffc107" Foreground="Black" Margin="5"/>
            <Button Content="Eliminar" Click="BtnEliminar_Click"
                    Width="100" Height="40"
                    Background="#dc3545" Foreground="White" Margin="5"/>
            <Button Content="Volver" Click="BtnVolver_Click"
                    Width="100" Height="40"
                    Background="#fd7e14" Foreground="White" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
