<Window x:Class="PantallaPublicaApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PantallaPublicaApp"
        mc:Ignorable="d"
        Title="Menú Organizador Publicidad"
        Height="500"
        Width="800"
        Background="#FF144734"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
            <TextBlock Text="Menú Organizador Publicidad"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       TextAlignment="Center"
                       Margin="0,0,0,20" />
            <ComboBox x:Name="cmbMonitores"
          Width="300"
          Height="35"
          Margin="0,0,0,10"
          FontSize="14"
          HorizontalContentAlignment="Center"
          VerticalContentAlignment="Center"/>

            <Button Content="Seleccionar productos para pantalla"
                    Width="300"
                    Height="45"
                    Background="#28a745"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="BtnSeleccionarProductos_Click"
                    BorderBrush="Transparent"
                    Cursor="Hand"/>

            <Button Content="Cargar Imágenes / Videos"
                    Width="300"
                    Height="45"
                    Background="#28a745"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="BtnCargarPublicidad_Click"
                    BorderBrush="Transparent"
                    Cursor="Hand"/>

            <Button Content="Mostrar Pantalla Pública"
                    Width="300"
                    Height="45"
                    Background="#28a745"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="BtnAbrirPantallaPublica_Click"
                    BorderBrush="Transparent"
                    Cursor="Hand"/>

            <Button Content="Salir"
        Width="300"
        Height="45"
        Background="#dc3545"
        Foreground="White"
        FontWeight="Bold"
        Click="BtnSalir_Click"
        BorderBrush="Transparent"
        Cursor="Hand"
        Margin="0,20,0,0"/>

        </StackPanel>
    </Grid>
</Window>
