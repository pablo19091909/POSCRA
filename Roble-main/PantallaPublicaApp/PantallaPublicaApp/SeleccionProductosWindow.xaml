<Window x:Class="PantallaPublicaApp.SeleccionProductosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar Productos para Pantalla"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#FF144734">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Seleccionar Productos para Pantalla"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,0,20"
                   HorizontalAlignment="Center"/>
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,60,0,10">
            <TextBox x:Name="txtBuscar"
             Width="300"
             Height="30"
             FontSize="16"
             Background="White"
             Foreground="Black"
             Margin="0,0,10,0"
             VerticalContentAlignment="Center"
             TextChanged="txtBuscar_TextChanged"
            Text="Buscar producto..."/>

            <Button Content="Limpiar"
            Width="100"
            Height="30"
            Background="#28a745"
            Foreground="White"
            FontWeight="Bold"
            Click="BtnLimpiarBuscar_Click"
            BorderBrush="Transparent"
            Cursor="Hand"/>
        </StackPanel>

        <DataGrid x:Name="dataGridProductos"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  SelectionMode="Extended"
                  CanUserAddRows="False"
                  Background="White"
                  Foreground="Black"
                  FontSize="16"
                  Margin="0,0,0,20">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Mostrar" Binding="{Binding Seleccionado}" Width="80"/>
                <DataGridTextColumn Header="Código" Binding="{Binding IdProducto}" Width="*"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Content="Guardar selección"
                Grid.Row="2"
                Height="40"
                Width="200"
                HorizontalAlignment="Center"
                Margin="0,10,0,0"
                Click="BtnGuardar_Click"
                Background="#28a745"
                Foreground="White"
                FontWeight="Bold"
                BorderBrush="Transparent"
                Cursor="Hand"/>
    </Grid>
</Window>
