<Window x:Class="PantallaPublicaApp.PantallaPublicaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pantalla Pública"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="True"
        Topmost="True"
        Background="#FF144734"
        Loaded="Window_Loaded">


    <DockPanel Margin="20">

        <!-- Encabezado -->
        <Grid DockPanel.Dock="Top" Height="120">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Bienvenidos Pulpería CRA"
               FontSize="48"
               FontWeight="Bold"
               Foreground="White"
               TextAlignment="Center"/>
                <TextBlock Text="SINPE Móvil: 8304-0041"
               FontSize="24"
               FontWeight="SemiBold"
               Foreground="White"
               TextAlignment="Center"
               Margin="0,10,0,0"/>
            </StackPanel>


            <Image Source="/PantallaPublicaApp;component/Assets/logo.png"
       Width="100"
       Height="100"
       Stretch="UniformToFill"
       Margin="10"
       Grid.Column="1"
       VerticalAlignment="Center"
       HorizontalAlignment="Right"/>
        </Grid>

        <!-- Contenido principal -->
        <Grid Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!-- Lista de productos -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                <TextBlock Text="PRODUCTOS DISPONIBLES" 
                           FontSize="36" 
                           FontWeight="Bold" 
                           Foreground="White"
                           TextAlignment="Center" 
                           Margin="0,0,0,30"/>

                <Border Background="White" CornerRadius="10" Padding="10" Height="400" ClipToBounds="True">
                    <ScrollViewer x:Name="ScrollProductos"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  IsHitTestVisible="False">
                        <StackPanel x:Name="StackProductos">
                            <StackPanel.RenderTransform>
                                <TranslateTransform x:Name="ProductosTransform" Y="0"/>
                            </StackPanel.RenderTransform>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Publicidad (Imagen o video) -->
            <Grid Grid.Column="1" x:Name="PublicidadArea" Margin="20">
                <Image x:Name="ImagenPublicidad"
                       Stretch="Uniform"
                       Visibility="Collapsed"/>
                <MediaElement x:Name="VideoPublicidad"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Stop"
                              Visibility="Collapsed"
                              MediaEnded="VideoPublicidad_MediaEnded"/>
            </Grid>
        </Grid>

    </DockPanel>
</Window>
